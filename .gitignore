# =========================
# 🔹 SYSTEM & IDE
# =========================
.vscode/
.idea/
.DS_Store
Thumbs.db

# =========================
# 🔹 PYTHON
# =========================
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ai_gpu/

# =========================
# 🔹 JUPYTER
# =========================
.ipynb_checkpoints/

# =========================
# 🔹 DATASETS (MAI SU GIT)
# =========================
# Ignora TUTTO il contenuto dentro le cartelle data, ma non la cartella in sé
**/data/*
!**/data/.gitkeep

# =========================
# 🔹 MODELS (PESANTI)
# =========================
**/models/*
!**/models/.gitkeep
*.pt
*.pth
*.onnx
*.h5
*.ckpt

# =========================
# 🔹 OUTPUT / TRAINING
# =========================
# Permettiamo la cartella outputs e tutto il suo contenuto
# (Grafici, dashboard XAI e log delle performance)
**/outputs/*
!**/outputs/.gitkeep
# Rimuovi o commenta la riga **/logs/ se vuoi caricare i log in outputs/logs/
#! **/logs/  <-- ELIMINATA PER MOSTRARE I RISULTATI

# =========================
# 🔹 OUTPUTS & RESULTS
# =========================
**/outputs/*
# Eccezioni: NON ignorare i .gitkeep e i file grafici/log che vogliamo su GitHub
!**/outputs/.gitkeep
!**/outputs/*.png
!**/outputs/*.csv
!**/outputs/*.txt


# =========================
# 🔹 FILE TEMPORANEI
# =========================
*.log
*.tmp
*.cache

# =========================
# 🔹 FILE SENSIBILI
# =========================
.env
*.env

# =========================
# 🔹 FILE SPECIFICI
# =========================
benchmark.md