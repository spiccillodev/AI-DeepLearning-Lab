# =========================
# 🔹 SYSTEM & IDE
# =========================
.vscode/
.idea/
.DS_Store
Thumbs.db

# =========================
# 🔹 PYTHON
# =========================
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ai_gpu/

# =========================
# 🔹 JUPYTER
# =========================
.ipynb_checkpoints/

# =========================
# 🔹 DATASETS (MAI SU GIT)
# =========================
# Ignora TUTTO il contenuto dentro le cartelle data, ma non la cartella in sé
**/data/*

# Fai un'eccezione per il file .gitkeep
!**/data/.gitkeep

# =========================
# 🔹 MODELS (PESANTI)
# =========================
**/models/*
!**/models/.gitkeep

# estensioni modelli (extra sicurezza ovunque si trovino)
*.pt
*.pth
*.onnx
*.h5
*.ckpt

# =========================
# 🔹 OUTPUT / TRAINING
# =========================
**/output/*
!**/output/.gitkeep
**/runs/
**/logs/

# =========================
# 🔹 FILE TEMPORANEI
# =========================
*.log
*.tmp
*.cache

# =========================
# 🔹 FILE SENSIBILI
# =========================
.env
*.env

